# ============================================================
# Purdue Company — Environment Configuration
# No API keys required for basic operation (uses Ollama locally)
# ============================================================

# --- Option 1: Ollama (LOCAL — no API key, completely free) ---
# Install: https://ollama.com  then run: ollama pull llama3.2
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# --- Option 2: Anthropic Claude (better quality, requires key) ---
# Uncomment and fill in if you have an Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL=anthropic/claude-sonnet-4-6

# --- CrewAI telemetry (optional) ---
CREWAI_TELEMETRY_OPT_OUT=true
